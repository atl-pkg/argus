import { describe, it, expect } from "./lib";

describe("argus self-test", fn() {
    it("assertEqual passes", fn() {
        expect(1 + 1).toBe(2);
    });

    it("string comparison", fn() {
        expect("hello").toBe("hello");
    });

    it("boolean", fn() {
        expect(true).toBe(true);
    });
});
